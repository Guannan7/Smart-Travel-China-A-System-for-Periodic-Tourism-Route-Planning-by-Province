# API密钥配置示例
# 请复制此文件并重命名为.env，然后填入您的实际API密钥

# DeepSeek API配置
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/v1

# 高德地图API配置
AMAP_API_KEY=
AMAP_API_URL=https://restapi.amap.com/v3

# 阿里云API配置
ALIYUN_API_KEY=
ALIYUN_APPCODE=your_aliyun_appcode

# 百度地图API配置（可选）
BAIDU_MAP_API_KEY=your_baidu_map_api_key

# 应用配置
FLASK_APP=app.py
FLASK_ENV=development
FLASK_DEBUG=1
